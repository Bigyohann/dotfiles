# Path configuration
path=(
  "$HOME/.npm-global/bin"
  "/usr/local/lib/node_modules/bin"
  "/opt/homebrew/opt/ruby/bin"
  "$HOME/flutter/bin"
  "$(go env GOPATH)/bin"
  "/Applications/WezTerm.app/Contents/MacOS"
  "$HOME/.antigravity/antigravity/bin"
  $path
)
export PATH
NODE_PATH=/usr/local/lib/node_modules

# Lazy-load rbenv
if command -v rbenv >/dev/null; then
  function rbenv() {
    unset -f rbenv
    eval "$(command rbenv init - zsh)"
    rbenv "$@"
  }
fi

. "$HOME/.local/bin/env"

function ubi { {{ .chezmoi.homeDir }}/Ubitransport/projects/ubitransport-cli/bin/run "$@" }
function ubitransport-cli { {{ .chezmoi.homeDir }}/Ubitransport/projects/ubitransport-cli/bin/run "$@" }

# Lazy-load Google Cloud SDK
function gcloud() {
  unset -f gcloud
  if [ -f '{{ .chezmoi.homeDir }}/google-cloud-sdk/path.zsh.inc' ]; then . '{{ .chezmoi.homeDir }}/google-cloud-sdk/path.zsh.inc'; fi
  if [ -f '{{ .chezmoi.homeDir }}/google-cloud-sdk/completion.zsh.inc' ]; then . '{{ .chezmoi.homeDir }}/google-cloud-sdk/completion.zsh.inc'; fi
  gcloud "$@"
}
# Matawan Aliases
alias up="sh ~/Ubitransport/scripts/up.sh"
alias down="sh ~/Ubitransport/scripts/down.sh"
function run-make { ~/Ubitransport/scripts/run-make.sh "$@" }

# Useful Aliases

# Data & Docker
alias json='jq "."'
alias dcpl='docker compose logs -f'

# Navigation
alias ll='eza -lahF'
alias ..='cd ..'
alias ...='cd ../..'

# Git Shortcuts
alias gs='git status'
alias gl='git log --oneline --graph --decorate --all'
alias gc='git commit -m'

# System & Network
alias ports='lsof -i -P -n | grep LISTEN'
alias myip='curl ifconfig.me'
alias zopt='~/.local/bin/optimize_zsh.sh'

# Custom Alias Reminder
function myaliases() {
    echo "\n✨ My Custom Aliases ✨"
    echo "-----------------------"
    # Grabs lines starting with 'alias ' from .zshrc, removes 'alias ', and formats output
    grep -E "^alias " ~/.zshrc | sed "s/alias //" | awk -F'=' '{printf "\033[36m%-10s\033[0m %s\n", $1, $2}'
    echo ""
}

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


# File Listing
alias ls='eza'
