# Navigation
alias ll='ls -lahF'
alias ..='cd ..'
alias ...='cd ../..'

# Git Shortcuts
alias gs='git status'
alias gl='git log --oneline --graph --decorate --all'
alias gc='git commit -m'

# System & Network
alias ports='lsof -i -P -n | grep LISTEN'
alias myip='curl ifconfig.me'

# Custom Alias Reminder
function myaliases() {
    echo "\n✨ My Custom Aliases ✨"
    echo "-----------------------"
    # Grabs lines starting with 'alias ' from .zshrc, removes 'alias ', and formats output
    grep -E "^alias " ~/.zshrc | sed "s/alias //" | awk -F'=' '{printf "\033[36m%-10s\033[0m %s\n", $1, $2}'
    echo ""
}

