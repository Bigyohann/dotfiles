# Set personal aliases, overriding those provided by Oh My Zsh libs,
# plugins, and themes. Aliases can be placed here, though Oh My Zsh
# users are encouraged to define aliases within a top-level file in
# the $ZSH_CUSTOM folder, with .zsh extension. Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# For a full list of active aliases, run `alias`.
#
alias v="nvim"
alias dcpu="docker compose up -d"
alias dcps="docker compose ps"
alias dcpd="docker compose down"
alias dcpe="docker compose exec"
alias rt="dcpe php composer setup-test-database && dcpe php vendor/bin/phpunit --colors=always"
alias rtf="dcpe php vendor/bin/phpunit --colors=always"
alias cat="bat"
alias dr="dcpe php composer data:reload $argv"
alias cf="dcpe php composer cs-fixer $argv"
alias ms='docker rm -f $(docker ps -aq)'

setopt complete_aliases

export GOOGLE_CLOUD_PROJECT_ID="gemini-code-assist-484112"
export GOOGLE_CLOUD_PROJECT="gemini-code-assist-484112"

bindkey "^[[1;3C" forward-word
