# Enable Powerlevel10k instant prompt. Should stay at the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# Use a faster compinit by checking if the cache is older than 24h
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.m-1) ]]; then
  compinit -C
else
  compinit
fi

# Antidote - high performance plugin manager
zsh_plugins=${ZDOTDIR:-$HOME}/.zsh_plugins.zsh
if [[ ! -f $zsh_plugins || ${ZDOTDIR:-$HOME}/.zsh_plugins.txt -nt $zsh_plugins ]]; then
  source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
  antidote bundle <${ZDOTDIR:-$HOME}/.zsh_plugins.txt >$zsh_plugins
fi
source $zsh_plugins

zsh-defer source ~/.config/zsh/catppuccin_macchiato-zsh-syntax-highlighting.zsh

