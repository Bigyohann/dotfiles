#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

readonly SSH_DIR="{{ .chezmoi.homeDir }}/.ssh"
if [[ ! -d "$SSH_DIR" ]]; then
    mkdir -p "$SSH_DIR"
    chmod 700 "$SSH_DIR"
fi

generate_ssh_key() {
    local key_path="$1"
    local comment="$2"

    if [[ -f "$key_path" ]]; then
        return 0
    fi

    ssh-keygen -t ed25519 -C "$comment" -f "$key_path" -N ""
    chmod 600 "$key_path"
}

generate_ssh_key "${SSH_DIR}/id_ed25519_personal" "{{ .personal_email }}"
generate_ssh_key "${SSH_DIR}/id_ed25519_{{ .company_name }}" "{{ .work_email }}"
