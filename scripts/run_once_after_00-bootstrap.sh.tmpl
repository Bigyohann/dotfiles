#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

function info() { printf "\n\033[36mℹ️  %s\033[0m\n" "$1"; }
function success() { printf "\033[32m✅ %s\033[0m\n" "$1"; }
function error() { printf "\033[31m❌ %s\033[0m\n" "$1"; exit 1; }

if ! command -v nix &> /dev/null; then
    info "Installing Nix..."
    curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | sh -s -- install --no-confirm
    
    if [[ -e "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" ]]; then
        # shellcheck disable=SC1091
        . "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
    fi
fi

if ! command -v nix &> /dev/null && [[ -e "$HOME/.nix-profile/etc/profile.d/nix.sh" ]]; then
    # shellcheck disable=SC1091
    . "$HOME/.nix-profile/etc/profile.d/nix.sh"
fi

if command -v nix &> /dev/null; then
    if ! command -v home-manager &> /dev/null; then
        info "Installing Home Manager..."
        nix-channel --add https://github.com/nix-community/home-manager/archive/master.tar.gz home-manager
        nix-channel --update
        export NIX_PATH=$HOME/.nix-defexpr/channels${NIX_PATH:+:}$NIX_PATH
        nix-shell '<home-manager>' -A install
    fi
    
    info "Applying Home Manager configuration..."
    home-manager switch
fi

info "Installing Neovim from source..."

if [[ "$OSTYPE" == "darwin"* ]]; then
    if command -v brew &> /dev/null; then
        brew install ninja libtool gettext cmake curl
    fi
elif [[ -f /etc/debian_version ]]; then
    sudo apt-get update
    sudo apt-get install -y ninja-build gettext libtool libtool-bin autoconf automake cmake g++ pkg-config unzip curl
fi

BUILD_ROOT="{{ .chezmoi.homeDir }}/.local/src"
if [[ ! -d "$BUILD_ROOT" ]]; then mkdir -p "$BUILD_ROOT"; fi
NVIM_DIR="$BUILD_ROOT/neovim"

if [[ -d "$NVIM_DIR" ]]; then
    cd "$NVIM_DIR"
    git fetch --all --tags
else
    git clone https://github.com/neovim/neovim "$NVIM_DIR"
    cd "$NVIM_DIR"
fi

git checkout stable
git pull origin stable

make clean
make CMAKE_BUILD_TYPE=RelWithDebInfo CMAKE_INSTALL_PREFIX="{{ .chezmoi.homeDir }}/.local"
make install

success "Setup complete"
"{{ .chezmoi.homeDir }}/.local/bin/nvim" --version | head -n 1
